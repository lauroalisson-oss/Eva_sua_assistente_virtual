generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ORGANIZAÇÃO (Multi-Empresa)
// ============================================
model Organization {
  id              String        @id @default(cuid())
  name            String
  slug            String        @unique   // URL-friendly identifier
  email           String        @unique
  phone           String?                 // Telefone da empresa
  plan            OrgPlan       @default(STARTER)
  planExpiresAt   DateTime?
  isActive        Boolean       @default(true)
  systemPrompt    String?       @db.Text  // Prompt personalizado global
  welcomeMessage  String?                 // Mensagem de boas-vindas
  businessHours   Json?                   // { "seg": "09:00-18:00", ... }
  settings        Json          @default("{}")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relações
  instances       Instance[]
  members         OrgMember[]
  knowledgeDocs   KnowledgeDoc[]

  @@map("organizations")
}

enum OrgPlan {
  STARTER       // R$97/mês — 1 número, 1.000 msgs, 500 conv livre
  BUSINESS      // R$297/mês — 3 números, 10.000 msgs, 5.000 conv livre
  ENTERPRISE    // R$797/mês — Ilimitados

  @@map("org_plan")
}

// ============================================
// INSTÂNCIA WHATSAPP (cada número conectado)
// ============================================
model Instance {
  id              String        @id @default(cuid())
  orgId           String
  instanceName    String        @unique   // Nome na Evolution API
  phone           String        @unique   // Número WhatsApp conectado
  displayName     String?                 // Nome de exibição
  status          InstanceStatus @default(DISCONNECTED)
  config          Json          @default("{}")
  webhookUrl      String?                 // URL do webhook configurado
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relações
  org             Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenants         Tenant[]      // Múltiplos tenants (clientes que falam com esta instância)

  @@index([orgId])
  @@map("instances")
}

enum InstanceStatus {
  CONNECTED
  DISCONNECTED
  CONNECTING
  BANNED

  @@map("instance_status")
}

// ============================================
// MEMBROS DA ORGANIZAÇÃO (usuários do painel)
// ============================================
model OrgMember {
  id              String        @id @default(cuid())
  orgId           String
  name            String
  email           String
  passwordHash    String                  // bcrypt hash
  role            MemberRole    @default(ADMIN)
  isActive        Boolean       @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relações
  org             Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, email])
  @@index([email])
  @@map("org_members")
}

enum MemberRole {
  OWNER         // Dono — acesso total
  ADMIN         // Administrador — quase tudo
  OPERATOR      // Operador — atende conversas, vê relatórios
  VIEWER        // Visualizador — só lê

  @@map("member_role")
}

// ============================================
// BASE DE CONHECIMENTO DA ORGANIZAÇÃO (RAG)
// ============================================
model KnowledgeDoc {
  id              String        @id @default(cuid())
  orgId           String
  title           String
  content         String        @db.Text
  category        String        @default("geral")
  tags            String[]
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relações
  org             Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, category])
  @@index([orgId, isActive])
  @@map("knowledge_docs")
}

// ============================================
// TENANT (Multi-tenancy — mantido para retrocompatibilidade)
// ============================================
model Tenant {
  id           String        @id @default(cuid())
  name         String
  phone        String        @unique  // Número WhatsApp principal
  email        String?
  plan         Plan          @default(BASIC)
  planExpiresAt DateTime?
  isActive     Boolean       @default(true)
  timezone     String        @default("America/Bahia")
  settings     Json          @default("{}")
  instanceId   String?                 // Vinculação com instância da organização
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relações
  instance     Instance?     @relation(fields: [instanceId], references: [id])
  events       Event[]
  transactions Transaction[]
  notes        Note[]
  budgets      Budget[]

  @@index([instanceId])
  @@map("tenants")
}

enum Plan {
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

// ============================================
// AGENDA — Eventos e Compromissos
// ============================================
model Event {
  id             String        @id @default(cuid())
  tenantId       String
  title          String
  description    String?
  location       String?
  startAt        DateTime
  endAt          DateTime?
  category       EventCategory @default(WORK)
  recurrenceRule String?       // RRULE format (ex: "FREQ=WEEKLY;BYDAY=MO")
  reminderConfig Json          @default("[{\"minutes\": 60}, {\"minutes\": 1440}]")
  status         EventStatus   @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  // Relações
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  notes          Note[]

  @@index([tenantId, startAt])
  @@index([tenantId, status])
  @@map("events")
}

enum EventCategory {
  WORK
  PERSONAL
  FINANCIAL
  HEALTH
}

enum EventStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

// ============================================
// FINANCEIRO — Transações
// ============================================
model Transaction {
  id          String          @id @default(cuid())
  tenantId    String
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  category    String          // Categoria (ex: "alimentacao", "transporte")
  subcategory String?         // Subcategoria opcional
  source      String?         // Fonte de receita (ex: "Smart Next", "IBGE")
  description String
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relações
  tenant      Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId, date])
  @@index([tenantId, type, date])
  @@index([tenantId, category])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
}

// ============================================
// FINANCEIRO — Orçamentos e Limites
// ============================================
model Budget {
  id             String   @id @default(cuid())
  tenantId       String
  month          Int      // 1-12
  year           Int
  globalLimit    Decimal  @db.Decimal(12, 2)
  categoryLimits Json     @default("{}") // { "alimentacao": 2000, "transporte": 1000 }
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relações
  tenant         Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, month, year])
  @@map("budgets")
}

// ============================================
// ANOTAÇÕES
// ============================================
model Note {
  id            String   @id @default(cuid())
  tenantId      String
  content       String
  tags          String[] // Array de tags (ex: ["urgente", "follow-up"])
  pinned        Boolean  @default(false)
  linkedEventId String?  // Vinculação opcional com evento
  sourceType    String   @default("text") // "text" ou "audio"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  // Relações
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  linkedEvent   Event?   @relation(fields: [linkedEventId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, pinned])
  @@map("notes")
}

// ============================================
// AUDIT LOG (Rastreamento de ações)
// ============================================
model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  action     String   // "CREATE", "UPDATE", "DELETE"
  entity     String   // "Event", "Transaction", "Note", "Budget"
  entityId   String   // ID do registro afetado
  changes    Json?    // { field: { from: old, to: new } }
  metadata   Json?    // Contexto adicional (IP, source, etc)
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([entity, entityId])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ============================================
// CONVERSA LIVRE — Agente Virtual / Atendente
// ============================================
model ConversationConfig {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  isEnabled       Boolean  @default(false)
  agentName       String   @default("EVA")           // Nome do agente (personalizável)
  businessName    String?                             // Nome da empresa
  businessSegment String?                             // Segmento (loja, clínica, etc.)
  personality     String   @default("profissional_amigavel") // profissional_amigavel, formal, descontraido
  systemPrompt    String?                             // Prompt customizado pelo dono
  greeting        String?                             // Mensagem de boas-vindas personalizada
  salesMode       Boolean  @default(false)            // Ativar técnicas de fechamento de venda
  maxHistoryMessages Int   @default(20)               // Mensagens de contexto por conversa
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relações
  knowledgeBase   KnowledgeEntry[]
  conversations   Conversation[]

  @@map("conversation_configs")
}

model KnowledgeEntry {
  id               String   @id @default(cuid())
  configId         String
  category         String                             // "produto", "servico", "faq", "politica", "preco"
  title            String                             // Ex: "Corte de cabelo masculino"
  content          String                             // Descrição detalhada
  price            Decimal? @db.Decimal(12, 2)        // Preço se aplicável
  tags             String[]                           // Tags para busca semântica
  isActive         Boolean  @default(true)
  priority         Int      @default(0)               // Prioridade na resposta
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relações
  config           ConversationConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId, category])
  @@index([configId, isActive])
  @@map("knowledge_entries")
}

model Conversation {
  id               String   @id @default(cuid())
  configId         String
  customerPhone    String                             // Telefone do cliente que está conversando
  customerName     String?                            // Nome do cliente
  status           ConversationStatus @default(ACTIVE)
  sentiment        String?                            // "positivo", "neutro", "negativo"
  summary          String?                            // Resumo gerado por IA
  leadScore        Int      @default(0)               // 0-100, score de intenção de compra
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  closedAt         DateTime?

  // Relações
  config           ConversationConfig @relation(fields: [configId], references: [id])
  messages         ConversationMessage[]

  @@index([configId, customerPhone])
  @@index([configId, status])
  @@map("conversations")
}

enum ConversationStatus {
  ACTIVE
  PAUSED
  CLOSED
  TRANSFERRED  // Transferido para humano
}

model ConversationMessage {
  id               String   @id @default(cuid())
  conversationId   String
  role             MessageRole                        // USER ou ASSISTANT
  content          String
  tokenCount       Int?                               // Controle de custo
  processingTimeMs Int?
  createdAt        DateTime @default(now())

  // Relações
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("conversation_messages")
}

enum MessageRole {
  USER
  ASSISTANT
}

// ============================================
// LOGS DE MENSAGENS (Analytics)
// ============================================
model MessageLog {
  id               String   @id @default(cuid())
  tenantId         String
  direction        String   // "incoming" ou "outgoing"
  messageType      String   // "text", "audio", "document"
  content          String?  // Texto da mensagem (sanitizado)
  classifiedIntent String?  // Intent detectado
  classifierSource String?  // "rules" ou "ai"
  confidence       Float?   // Score de confiança
  processingTimeMs Int?     // Tempo de processamento em ms
  createdAt        DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([classifierSource, createdAt])
  @@map("message_logs")
}
