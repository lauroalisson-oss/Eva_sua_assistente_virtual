{
  "name": "eva-assistant",
  "version": "1.0.0",
  "description": "EVA — Executive Virtual Assistant | WhatsApp AI Secretary",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "keywords": ["whatsapp", "assistant", "ai", "secretary", "finance", "agenda"],
  "author": "Lauro Alisson",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.25.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "fastify": "^4.28.0",
    "groq-sdk": "^0.8.0",
    "ioredis": "^5.4.0",
    "node-cron": "^3.0.3",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.0",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "puppeteer": "^23.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9.9.0",
    "prettier": "^3.3.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^1.6.0"
  }
}
