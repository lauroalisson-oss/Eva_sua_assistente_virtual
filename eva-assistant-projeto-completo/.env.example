# ============================================
# EVA — Executive Virtual Assistant
# Copie este arquivo para .env e preencha
# ============================================

# --- Servidor ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# --- Banco de Dados ---
DATABASE_URL=postgresql://eva:eva_secret@localhost:5432/eva_db

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Claude API (Anthropic) ---
# Obter em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Groq API (Transcrição de Áudio) ---
# Obter em: https://console.groq.com/
GROQ_API_KEY=gsk_sua-chave-aqui

# --- Evolution API (WhatsApp) ---
# URL da sua instância Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-chave-evolution
EVOLUTION_INSTANCE=eva-bot

# --- Admin API ---
# Chave de acesso para endpoints /api/admin/* (mínimo 16 caracteres)
ADMIN_API_KEY=troque-esta-chave-em-producao-32chars

# --- Configurações do EVA ---
# Números autorizados (separados por vírgula, com DDI+DDD)
AUTHORIZED_PHONES=5575999999999
# Timezone padrão
DEFAULT_TIMEZONE=America/Bahia
# Hora do resumo diário (0-23)
DAILY_SUMMARY_HOUR=7
